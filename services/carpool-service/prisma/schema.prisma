// prisma/schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Ride {
  id             String      @id @default(cuid())
  userId         String
  fromLocation   String
  toLocation     String
  departureAt    DateTime
  vehicleType    String?
  vehicleName    String?
  price          Int
  totalSeats     Int
  bookedSeats    Int         @default(0)
  description    String?
  status         RideStatus  @default(OPEN)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  
  bookings       Booking[]
}

model Booking {
  id             String      @id @default(cuid())
  rideId         String
  userId         String
  status         BookingStatus @default(CONFIRMED)
  createdAt      DateTime    @default(now())
  
  ride           Ride        @relation(fields: [rideId], references: [id])
}

enum RideStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  PENDING
}